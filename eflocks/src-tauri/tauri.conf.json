{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eflocks",
  "version": "1.0.0",
  "identifier": "com.buer.eflocks",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "eflocks",
        "width": 480,
        "height": 350,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
